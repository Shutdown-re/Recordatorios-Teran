<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/holo_red_dark">

    <!-- Contenedor principal centrado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Ícono de alarma animado -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="🚨"
            android:textSize="80sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Título ALARMA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡ALARMA!"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:layout_marginBottom="48dp"
            android:shadowColor="#FF000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"/>

        <!-- Información en tarjeta -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/alarm_card_background"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Cliente -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cliente:"
                    android:textSize="14sp"
                    android:textColor="#FF888888"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="16dp"/>

                <!-- Equipo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipo:"
                    android:textSize="14sp"
                    android:textColor="#FF888888"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEquipo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Equipo"
                    android:textSize="20sp"
                    android:textColor="#FFFFFFFF"
                    android:layout_marginBottom="16dp"/>

                <!-- Fecha -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha:"
                    android:textSize="14sp"
                    android:textColor="#FF888888"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvFecha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha"
                    android:textSize="18sp"
                    android:textColor="#FFFFFFFF"/>

            </LinearLayout>

        </FrameLayout>

        <!-- Espaciador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:spacing="12dp">

            <Button
                android:id="@+id/btnAceptar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Aceptar"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:background="@drawable/btn_accept_background"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnSnooze"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Posponer 5 min"
                android:textSize="18sp"
                android:textColor="#FF333333"
                android:background="@drawable/btn_snooze_background"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
